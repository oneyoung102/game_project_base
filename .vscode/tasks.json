{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SFML",
            "type": "shell",
            "command": "/usr/bin/clang++",
            "args": [
                "-g",
                "-std=c++23",
                "src/main/main.cpp",
                "src/main/windowManager/windowManager.cpp",
                "src/resourceManager/fileManager/fileManager.cpp",
                "src/resourceManager/soundManager/soundManager.cpp",
                "src/resourceManager/printManager/printManager.cpp",
                "src/resourceManager/printManager/printObject/printObject.cpp",

                "src/resourceManager/printManager/printText/printText.cpp",
                "src/resourceManager/printManager/printText/printTextFlash.cpp",
                "src/resourceManager/printManager/printText/printTextZoom.cpp",

                "src/resourceManager/printManager/printButton/printButton.cpp",
                "src/resourceManager/printManager/printButton/printDialButton.cpp",

                "src/game/letManager/letManager.cpp",
                "src/game/pageManager/pageManager.cpp",
                "src/game/pages/page.cpp",

                "-o",
                "${workspaceFolder}/bin/game_project_base",
                "-Isrc",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-lsfml-audio"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc 활성 파일 빌드",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "디버거에서 생성된 작업입니다."
        }
    ]
}